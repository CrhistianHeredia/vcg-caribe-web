---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import StatBlock from '../components/ui/StatBlock.astro';
import ServiceCard from '../components/ui/ServiceCard.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';

const services = [
  {
    title: 'Ventanas y Puertas',
    description: 'Sistemas de ventanas corredizas, abatibles, fijos y proyectables en aluminio de alta calidad.',
    icon: 'window',
    href: '/servicios#ventanas',
  },
  {
    title: 'Barandales',
    description: 'Barandales y pasamanos en vidrio templado y aluminio para interiores y exteriores.',
    icon: 'railing',
    href: '/servicios#barandales',
  },
  {
    title: 'Muros Cortina',
    description: 'Fachadas de vidrio estructural para edificios comerciales y corporativos.',
    icon: 'building',
    href: '/servicios#muros-cortina',
  },
  {
    title: 'Cancelería Hotelera',
    description: 'Soluciones especializadas para hoteles y resorts de la Riviera Maya.',
    icon: 'hotel',
    href: '/servicios#hotelera',
  },
  {
    title: 'Proyectos Residenciales',
    description: 'Cancelería personalizada para casas y departamentos de lujo.',
    icon: 'home',
    href: '/servicios#residencial',
  },
  {
    title: 'Mantenimiento',
    description: 'Servicio de mantenimiento preventivo y correctivo para cancelería existente.',
    icon: 'tools',
    href: '/servicios#mantenimiento',
  },
];

const projects = [
  {
    title: 'Hotel Marque',
    category: 'Comercial',
    image: '/images/projects/hotel-marque.jpg',
    year: '2019',
    href: '/portafolio',
  },
  {
    title: 'Cielo Maya',
    category: 'Residencial',
    image: '/images/projects/cielo-maya-ventana.jpg',
    year: '2025',
    href: '/portafolio',
  },
  {
    title: 'Las Olas 71',
    category: 'Hotelero',
    image: '/images/projects/las-olas-71.jpg',
    year: '2025',
    href: '/portafolio',
  },
  {
    title: 'Now Jade Resort',
    category: 'Hotelero',
    image: '/images/projects/now-jade.jpg',
    year: '2020',
    href: '/portafolio',
  },
  {
    title: 'Hotel Calixta',
    category: 'Hotelero',
    image: '/images/projects/hotel-calixta.jpg',
    year: '2019',
    href: '/portafolio',
  },
  {
    title: 'Lote 266 Puerto Cancún',
    category: 'Residencial',
    image: '/images/projects/lote-266.jpg',
    year: '2025',
    href: '/portafolio',
  },
];

const stats = [
  { number: '15', suffix: '+', label: 'Años de experiencia' },
  { number: '500', suffix: '+', label: 'Proyectos completados' },
  { number: '200', suffix: '+', label: 'Clientes satisfechos' },
  { number: '2', suffix: '', label: 'Ubicaciones' },
];
---

<PageLayout page="home">
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img
        src="/images/projects/paravian-exterior.jpg"
        alt="VCG Caribe - Cancelería de Alta Calidad"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-deep/95 via-deep/85 to-deep/70"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-deep via-transparent to-deep/30"></div>
    </div>

    <!-- Background Pattern Overlay -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%2338bdf8&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>

    <div class="container mx-auto px-4 py-32 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Content -->
        <div class="text-white">
          <span class="inline-block text-accent font-semibold text-sm uppercase tracking-wider mb-4 animate-fade-in">
            Valor • Confianza • Garantía
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight animate-fade-in-up">
            Cancelería de <span class="gradient-text">Vidrio y Aluminio</span> de Alta Calidad
          </h1>
          <p class="text-white/70 text-lg md:text-xl mb-8 leading-relaxed animate-fade-in-up animation-delay-200">
            Expertos en soluciones de cancelería para proyectos hoteleros, residenciales y comerciales
            en Cancún, Riviera Maya y todo el sureste de México.
          </p>
          <div class="flex flex-wrap gap-4 animate-fade-in-up animation-delay-300">
            <Button href="/contacto" variant="primary" size="lg">
              Solicitar Cotización
            </Button>
            <Button href="/portafolio" variant="outline" size="lg">
              Ver Proyectos
            </Button>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 pt-12 border-t border-white/10 animate-fade-in-up animation-delay-400">
            {stats.map((stat) => (
              <StatBlock number={stat.number} suffix={stat.suffix} label={stat.label} dark={true} />
            ))}
          </div>
        </div>

        <!-- Animated Window SVG -->
        <div class="relative hidden lg:flex items-center justify-center">
          <div id="hero-animation" class="w-full max-w-lg">
            <svg viewBox="0 0 400 500" class="w-full h-auto" id="window-svg">
              <!-- Window Frame -->
              <g id="window-frame" class="opacity-0">
                <!-- Outer Frame -->
                <rect x="50" y="50" width="300" height="400" fill="none" stroke="#38bdf8" stroke-width="4" rx="4" class="frame-path"/>

                <!-- Horizontal Divider -->
                <line x1="50" y1="250" x2="350" y2="250" stroke="#38bdf8" stroke-width="3" class="frame-path"/>

                <!-- Vertical Divider -->
                <line x1="200" y1="50" x2="200" y2="450" stroke="#38bdf8" stroke-width="3" class="frame-path"/>

                <!-- Inner frames for panes -->
                <rect x="60" y="60" width="130" height="180" fill="none" stroke="#38bdf8" stroke-width="2" rx="2" class="frame-path"/>
                <rect x="210" y="60" width="130" height="180" fill="none" stroke="#38bdf8" stroke-width="2" rx="2" class="frame-path"/>
                <rect x="60" y="260" width="130" height="180" fill="none" stroke="#38bdf8" stroke-width="2" rx="2" class="frame-path"/>
                <rect x="210" y="260" width="130" height="180" fill="none" stroke="#38bdf8" stroke-width="2" rx="2" class="frame-path"/>
              </g>

              <!-- Glass Panes -->
              <g id="glass-panes">
                <rect x="65" y="65" width="120" height="170" fill="#38bdf8" opacity="0" class="glass-pane">
                  <animate attributeName="opacity" from="0" to="0.15" dur="0.5s" begin="1.5s" fill="freeze"/>
                </rect>
                <rect x="215" y="65" width="120" height="170" fill="#38bdf8" opacity="0" class="glass-pane">
                  <animate attributeName="opacity" from="0" to="0.15" dur="0.5s" begin="1.7s" fill="freeze"/>
                </rect>
                <rect x="65" y="265" width="120" height="170" fill="#38bdf8" opacity="0" class="glass-pane">
                  <animate attributeName="opacity" from="0" to="0.15" dur="0.5s" begin="1.9s" fill="freeze"/>
                </rect>
                <rect x="215" y="265" width="120" height="170" fill="#38bdf8" opacity="0" class="glass-pane">
                  <animate attributeName="opacity" from="0" to="0.15" dur="0.5s" begin="2.1s" fill="freeze"/>
                </rect>
              </g>

              <!-- Reflection Lines -->
              <g id="reflections" opacity="0">
                <line x1="85" y1="85" x2="145" y2="145" stroke="white" stroke-width="2" opacity="0.3" class="reflection"/>
                <line x1="235" y1="85" x2="295" y2="145" stroke="white" stroke-width="2" opacity="0.3" class="reflection"/>
                <line x1="85" y1="285" x2="145" y2="345" stroke="white" stroke-width="2" opacity="0.3" class="reflection"/>
                <line x1="235" y1="285" x2="295" y2="345" stroke="white" stroke-width="2" opacity="0.3" class="reflection"/>
              </g>

              <!-- Handle -->
              <g id="handle" opacity="0">
                <rect x="190" y="240" width="20" height="20" fill="#1E3A5F" rx="2"/>
                <circle cx="200" cy="250" r="4" fill="#38bdf8"/>
              </g>
            </svg>
          </div>

          <!-- Floating elements -->
          <div class="absolute -top-10 -right-10 w-20 h-20 bg-accent/20 rounded-full blur-xl animate-float"></div>
          <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-accent/10 rounded-full blur-2xl animate-float animation-delay-200"></div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-20 lg:py-32 bg-light">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative img-frame-accent img-frame-dots group">
          <div class="img-frame-gradient">
            <img
              src="/images/projects/paravian.jpg"
              alt="VCG Caribe - Proyecto Paravian"
              class="w-full h-[400px] object-cover img-shine transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
        </div>

        <div>
          <SectionHeader
            kicker="Sobre Nosotros"
            title="Más de 15 años transformando espacios"
            align="left"
          />
          <p class="text-muted text-lg leading-relaxed mb-6">
            En VCG Caribe somos especialistas en cancelería de vidrio y aluminio.
            Nuestro nombre representa nuestros valores fundamentales: <strong class="text-deep">Valor</strong>,
            <strong class="text-deep">Confianza</strong> y <strong class="text-deep">Garantía</strong>.
          </p>
          <p class="text-muted leading-relaxed mb-8">
            Desde nuestra sede en Cancún y sucursal en Mérida, atendemos proyectos
            hoteleros, residenciales y comerciales en toda la Península de Yucatán
            y el sureste de México, ofreciendo soluciones que combinan diseño,
            funcionalidad y durabilidad.
          </p>
          <Button href="/nosotros" variant="primary">
            Conocer Más
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 lg:py-32 bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        kicker="Nuestros Servicios"
        title="Soluciones completas en cancelería"
        subtitle="Ofrecemos una amplia gama de productos y servicios para satisfacer las necesidades de cada proyecto."
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service, index) => (
          <div class="reveal" style={`animation-delay: ${index * 100}ms`}>
            <ServiceCard {...service} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="py-20 lg:py-32 bg-light">
    <div class="container mx-auto px-4">
      <SectionHeader
        kicker="Portafolio"
        title="Proyectos Destacados"
        subtitle="Conoce algunos de nuestros trabajos más recientes en hoteles, residencias y edificios comerciales."
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, index) => (
          <div class="reveal" style={`animation-delay: ${index * 100}ms`}>
            <ProjectCard {...project} />
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <Button href="/portafolio" variant="outline">
          Ver Todos los Proyectos
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 lg:py-32 bg-deep-gradient relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%2338bdf8&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>

    <div class="container mx-auto px-4 text-center relative z-10">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        ¿Tienes un proyecto en mente?
      </h2>
      <p class="text-white/70 text-lg max-w-2xl mx-auto mb-8">
        Contáctanos para una cotización sin compromiso. Nuestro equipo de expertos
        está listo para ayudarte a hacer realidad tu visión.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/contacto" variant="primary" size="lg">
          Solicitar Cotización
        </Button>
        <a href="https://wa.me/529982344274" target="_blank" class="btn-white inline-flex items-center gap-2 px-6 py-4 text-lg">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  // Hero Animation - using CSS animations triggered by class
  document.addEventListener('DOMContentLoaded', () => {
    // Animate window frame
    const windowFrame = document.getElementById('window-frame');
    if (windowFrame) {
      windowFrame.classList.add('animate-in');
    }

    // Animate reflections and handle after frame
    setTimeout(() => {
      const reflections = document.getElementById('reflections');
      const handle = document.getElementById('handle');
      if (reflections) reflections.classList.add('animate-in');
      if (handle) handle.classList.add('animate-in');
    }, 1500);

    // Scroll reveal
    const revealElements = document.querySelectorAll('.reveal');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    revealElements.forEach(el => observer.observe(el));

    // Stats counter animation
    const statCounters = document.querySelectorAll('.stat-counter');

    const animateCounter = (el: Element, target: number) => {
      const duration = 2000;
      const steps = 60;
      const increment = target / steps;
      let current = 0;
      const interval = duration / steps;

      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          el.textContent = target.toString();
          clearInterval(timer);
        } else {
          el.textContent = Math.floor(current).toString();
        }
      }, interval);
    };

    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const target = entry.target;
          const value = parseInt(target.getAttribute('data-target') || '0');
          animateCounter(target, value);
          counterObserver.unobserve(target);
        }
      });
    }, { threshold: 0.5 });

    statCounters.forEach(counter => counterObserver.observe(counter));
  });
</script>

<style>
  .frame-path {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
  }

  #window-frame {
    opacity: 0;
    transition: opacity 0.5s ease-out;
  }

  #window-frame.animate-in {
    opacity: 1;
  }

  #window-frame.animate-in .frame-path {
    animation: drawPath 1.5s ease-out forwards;
  }

  @keyframes drawPath {
    to {
      stroke-dashoffset: 0;
    }
  }

  #reflections, #handle {
    opacity: 0;
    transition: all 0.5s ease-out;
  }

  #reflections.animate-in {
    opacity: 1;
  }

  #handle.animate-in {
    opacity: 1;
    transform: scale(1);
  }

  #handle {
    transform: scale(0.5);
  }
</style>
