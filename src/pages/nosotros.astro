---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import Card from '../components/ui/Card.astro';
import StatBlock from '../components/ui/StatBlock.astro';
import Button from '../components/ui/Button.astro';

const values = [
  {
    title: 'Valor',
    description: 'Ofrecemos productos y servicios de la más alta calidad, utilizando materiales premium y técnicas de vanguardia que garantizan resultados excepcionales.',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
  },
  {
    title: 'Confianza',
    description: 'Construimos relaciones duraderas con nuestros clientes basadas en la transparencia, comunicación efectiva y cumplimiento de compromisos.',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  },
  {
    title: 'Garantía',
    description: 'Respaldamos cada proyecto con garantía integral, asegurando la satisfacción total de nuestros clientes y la durabilidad de nuestros productos.',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  },
];

const stats = [
  { number: '15', suffix: '+', label: 'Años de experiencia', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>` },
  { number: '500', suffix: '+', label: 'Proyectos completados', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>` },
  { number: '200', suffix: '+', label: 'Clientes satisfechos', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>` },
  { number: '50', suffix: '+', label: 'Profesionales', icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>` },
];

const timeline = [
  { year: '2009', title: 'Fundación', description: 'Iniciamos operaciones en Cancún con el sueño de transformar la industria de la cancelería en el sureste mexicano.' },
  { year: '2013', title: 'Primer Gran Proyecto', description: 'Completamos nuestro primer proyecto hotelero de gran escala, marcando el inicio de nuestra especialización en el sector turístico.' },
  { year: '2018', title: 'Expansión Regional', description: 'Ampliamos nuestra cobertura a toda la Riviera Maya, consolidándonos como referente en cancelería de alta gama.' },
  { year: '2022', title: 'Apertura Mérida', description: 'Inauguramos nuestra sucursal en Mérida, extendiendo nuestros servicios a toda la Península de Yucatán.' },
  { year: '2024', title: 'Innovación Continua', description: 'Incorporamos tecnología de punta y sistemas sustentables, reforzando nuestro compromiso con la excelencia.' },
];

const services = [
  { title: 'Ventanas y Puertas', icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/><line x1="3" y1="12" x2="21" y2="12" stroke-width="1.5"/><line x1="12" y1="3" x2="12" y2="21" stroke-width="1.5"/></svg>` },
  { title: 'Barandales', icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 6v12M20 6v12M4 18h16M8 6v12M12 6v12M16 6v12"/></svg>` },
  { title: 'Muros Cortina', icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>` },
  { title: 'Cancelería Hotelera', icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/></svg>` },
];
---

<PageLayout
  title="Nosotros - VCG Caribe"
  description="Conoce la historia, misión y valores de VCG Caribe. Más de 15 años de experiencia en cancelería de vidrio y aluminio."
>
  <!-- Hero with Background Image -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img
        src="/images/projects/paravian-interior.jpg"
        alt="VCG Caribe Proyectos"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-deep/95 via-deep/80 to-deep/60"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-deep via-transparent to-transparent"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 relative z-10 py-20">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-accent/20 text-accent font-semibold text-sm uppercase tracking-wider rounded-full mb-6 backdrop-blur-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          Sobre Nosotros
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          Valor, Confianza y<br/>
          <span class="gradient-text">Garantía</span>
        </h1>
        <p class="text-white/80 text-lg md:text-xl mb-8 leading-relaxed">
          Más de 15 años transformando espacios con soluciones de cancelería
          de la más alta calidad en el sureste de México. Somos líderes en
          vidrio y aluminio arquitectónico.
        </p>

        <!-- Quick Services -->
        <div class="flex flex-wrap gap-4">
          {services.map((service) => (
            <div class="flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg border border-white/10 text-white/90 text-sm">
              <span class="text-accent" set:html={service.icon.replace('w-8 h-8', 'w-5 h-5')} />
              {service.title}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Decorative Element -->
    <div class="absolute right-0 bottom-0 w-1/3 h-full hidden lg:block">
      <div class="absolute bottom-20 right-20 w-64 h-64 border-2 border-accent/30 rounded-3xl transform rotate-12"></div>
      <div class="absolute bottom-32 right-32 w-48 h-48 border-2 border-white/10 rounded-2xl transform -rotate-6"></div>
    </div>
  </section>

  <!-- Values Section - Modern Cards -->
  <section class="py-20 lg:py-32 bg-light relative overflow-hidden">
    <!-- Background Decoration -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-navy/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

    <div class="container mx-auto px-4 relative z-10">
      <SectionHeader
        kicker="Nuestros Valores"
        title="Lo que nos define"
        subtitle="Los pilares fundamentales que guían cada proyecto y cada relación con nuestros clientes."
      />

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        {values.map((value, index) => (
          <div class={`group relative reveal`} style={`animation-delay: ${index * 150}ms`}>
            <!-- Card -->
            <div class="relative bg-white rounded-[2rem_0.5rem_2rem_0.5rem] p-8 shadow-xl hover:shadow-2xl transition-all duration-500 h-full border border-gray-100 group-hover:border-accent/30">
              <!-- Icon Container -->
              <div class="w-20 h-20 bg-gradient-to-br from-accent/20 to-navy/10 rounded-2xl flex items-center justify-center mb-6 text-accent group-hover:scale-110 transition-transform duration-500">
                <span set:html={value.icon} />
              </div>

              <!-- Content -->
              <h3 class="text-2xl font-bold text-deep mb-4 group-hover:text-accent transition-colors">{value.title}</h3>
              <p class="text-muted leading-relaxed">{value.description}</p>

              <!-- Decorative Corner -->
              <div class="absolute top-0 right-0 w-16 h-16 bg-gradient-to-bl from-accent/10 to-transparent rounded-tr-[0.5rem] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>

            <!-- Background Accent -->
            <div class="absolute -bottom-3 -right-3 w-full h-full bg-gradient-to-br from-accent/20 to-navy/10 rounded-[2rem_0.5rem_2rem_0.5rem] -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Historia Timeline -->
  <section class="py-20 lg:py-32 bg-deep-gradient-mesh relative overflow-hidden">
    <div class="container mx-auto px-4">
      <SectionHeader
        kicker="Nuestra Historia"
        title="Una trayectoria de excelencia"
        subtitle="Desde 2009, hemos crecido junto con la región, participando en los proyectos más emblemáticos del sureste mexicano."
        dark={true}
      />

      <!-- Timeline -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Timeline Line -->
        <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-accent via-accent/50 to-accent/20"></div>

        {timeline.map((item, index) => (
          <div class={`relative flex items-center gap-8 mb-12 last:mb-0 reveal ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`} style={`animation-delay: ${index * 100}ms`}>
            <!-- Content -->
            <div class={`flex-1 ${index % 2 === 0 ? 'md:text-right md:pr-12' : 'md:text-left md:pl-12'} pl-20 md:pl-0`}>
              <div class="glass-card-dark p-6 rounded-2xl inline-block">
                <span class="text-accent font-bold text-lg">{item.year}</span>
                <h3 class="text-xl font-bold text-white mt-1 mb-2">{item.title}</h3>
                <p class="text-white/70 text-sm leading-relaxed">{item.description}</p>
              </div>
            </div>

            <!-- Center Dot -->
            <div class="absolute left-8 md:left-1/2 w-4 h-4 bg-accent rounded-full transform -translate-x-1/2 shadow-lg shadow-accent/50">
              <div class="absolute inset-0 bg-accent rounded-full animate-ping opacity-25"></div>
            </div>

            <!-- Spacer for alternating layout -->
            <div class="hidden md:block flex-1"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Misión y Visión -->
  <section class="py-20 lg:py-32 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Image Side -->
        <div class="relative group order-2 lg:order-1">
          <div class="p-[3px] rounded-[2rem_0.5rem_2rem_0.5rem] bg-gradient-to-br from-accent via-navy to-accent shadow-2xl">
            <img
              src="/images/projects/cielo-maya-arquitectura.jpg"
              alt="VCG Caribe - Excelencia en Cancelería"
              class="w-full h-[500px] object-cover rounded-[calc(2rem-3px)_calc(0.5rem-3px)_calc(2rem-3px)_calc(0.5rem-3px)]"
              loading="lazy"
            />
          </div>
          <!-- Decorative Elements -->
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-accent/10 rounded-2xl -z-10 group-hover:-bottom-8 group-hover:-left-8 transition-all duration-500"></div>
          <div class="absolute -top-6 -right-6 w-24 h-24 border-2 border-accent/30 rounded-xl -z-10 group-hover:-top-8 group-hover:-right-8 transition-all duration-500"></div>
        </div>

        <!-- Content Side -->
        <div class="order-1 lg:order-2">
          <SectionHeader
            kicker="Nuestro Propósito"
            title="Transformando espacios con excelencia"
            align="left"
          />

          <!-- Mission -->
          <div class="mb-8 p-6 bg-light rounded-2xl border-l-4 border-accent">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-accent/20 rounded-lg flex items-center justify-center text-accent">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-deep">Misión</h3>
            </div>
            <p class="text-muted leading-relaxed">
              Proveer soluciones integrales de cancelería de vidrio y aluminio que superen
              las expectativas de nuestros clientes, combinando innovación, calidad y servicio
              excepcional para transformar espacios.
            </p>
          </div>

          <!-- Vision -->
          <div class="p-6 bg-light rounded-2xl border-l-4 border-navy">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 bg-navy/20 rounded-lg flex items-center justify-center text-navy">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-deep">Visión</h3>
            </div>
            <p class="text-muted leading-relaxed">
              Ser reconocidos como la empresa líder en cancelería de vidrio y aluminio
              en el sureste de México, distinguiéndonos por nuestra excelencia operativa
              y capacidad de innovación constante.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20 lg:py-32 bg-deep-gradient relative overflow-hidden">
    <!-- Decorative Pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%2338bdf8&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <SectionHeader
        kicker="En Números"
        title="Resultados que hablan"
        dark={true}
      />

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {stats.map((stat, index) => (
          <div class="group reveal" style={`animation-delay: ${index * 100}ms`}>
            <div class="glass-card-dark p-8 rounded-2xl text-center h-full hover:bg-white/10 transition-all duration-500 border border-white/10 hover:border-accent/30">
              <div class="w-14 h-14 bg-accent/20 rounded-xl flex items-center justify-center mx-auto mb-4 text-accent group-hover:scale-110 transition-transform">
                <span set:html={stat.icon} />
              </div>
              <div class="text-4xl md:text-5xl font-bold text-white mb-2">
                {stat.number}<span class="text-accent">{stat.suffix}</span>
              </div>
              <div class="text-white/60 text-sm uppercase tracking-wider">{stat.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ubicaciones -->
  <section class="py-20 lg:py-32 bg-light">
    <div class="container mx-auto px-4">
      <SectionHeader
        kicker="Ubicaciones"
        title="Dónde encontrarnos"
        subtitle="Con presencia en Cancún y Mérida, estamos cerca de ti para atender tus proyectos en toda la Península de Yucatán."
      />

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Cancún -->
        <div class="group">
          <div class="bg-white rounded-[2rem_0.5rem_2rem_0.5rem] p-8 shadow-xl hover:shadow-2xl transition-all duration-500 border border-gray-100 h-full">
            <div class="flex items-start gap-5">
              <div class="w-16 h-16 bg-gradient-to-br from-accent/20 to-navy/10 rounded-2xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="text-xl font-bold text-deep">Matriz Cancún</h3>
                  <span class="px-2 py-0.5 bg-accent/10 text-accent text-xs font-semibold rounded-full">Principal</span>
                </div>
                <p class="text-muted mb-4">Av. Talleres, Región 92, Cancún, Quintana Roo</p>

                <div class="space-y-3">
                  <a href="tel:+529982344274" class="flex items-center gap-3 text-muted hover:text-accent transition-colors">
                    <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    998 234 4274
                  </a>
                  <div class="flex items-center gap-3 text-muted">
                    <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span>Lun-Vie 8:00 AM - 6:00 PM | Sáb 8:00 AM - 1:00 PM</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Mérida -->
        <div class="group">
          <div class="bg-white rounded-[0.5rem_2rem_0.5rem_2rem] p-8 shadow-xl hover:shadow-2xl transition-all duration-500 border border-gray-100 h-full">
            <div class="flex items-start gap-5">
              <div class="w-16 h-16 bg-gradient-to-br from-accent/20 to-navy/10 rounded-2xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="text-xl font-bold text-deep">Sucursal Mérida</h3>
                  <span class="px-2 py-0.5 bg-navy/10 text-navy text-xs font-semibold rounded-full">Nueva</span>
                </div>
                <p class="text-muted mb-4">Calle 92 No. 503 D, Centro, CP. 97000, Mérida, Yucatán</p>

