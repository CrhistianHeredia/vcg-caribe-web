    specs: ['Fachada comercial', 'Pivotes piso-cielo', 'Vidrio 10mm', 'Estructural'],
    size: 'normal',
  },
  {
    title: 'Hotel Calixta',
    category: 'Hotelero',
    location: 'Playa del Carmen, Q. Roo',
