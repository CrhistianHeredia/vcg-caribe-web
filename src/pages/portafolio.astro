    specs: ['Estilo asiático', 'Templado 12mm', 'Acabado bronce', 'Gran formato'],
    size: 'normal',
  },
  {
    title: 'Cielo Maya Arquitectura',
    category: 'Residencial',
    location: 'Puerto Aventuras, Q. Roo',
    image: '/images/projects/cielo-maya-arquitectura.jpg',
    year: '2025',
    description: 'Arquitectura contemporánea con techos de madera y vidrio, tragaluces de gran formato con marco de aluminio, sistema de ventilación natural con louvers y acabados de lujo en toda la estructura.',
    specs: ['Techos madera', 'Tragaluces', 'Louvers', 'Ventilación natural'],
    size: 'normal',
  },
  {
    title: 'Hotel Marque',
    category: 'Comercial',
    location: 'Playa del Carmen, Q. Roo',
    image: '/images/projects/hotel-marque.jpg',
    year: '2019',
    description: 'Edificio comercial de 5 niveles con fachada de aluminio y ventanas de gran formato, balcones con barandales de aluminio color madera, sistema de ventilación cruzada y acabados resistentes al clima costero.',
    specs: ['5 niveles', 'Gran formato', 'Ventilación cruzada', 'Anti-costero'],
    size: 'normal',
  },
  {
    title: 'Lote 266 Puerto Cancún',
    category: 'Residencial',
    location: 'Puerto Cancún, Q. Roo',
    image: '/images/projects/lote-266.jpg',
    year: '2025',
    description: 'Residencia moderna con fachada de aluminio blanco y ventanas de piso a techo, jardín con paisajismo tropical, barandales de vidrio templado y sistema de iluminación arquitectónica integrada.',
    specs: ['Aluminio blanco', 'Piso a techo', 'Paisajismo', 'Iluminación LED'],
    size: 'normal',
  },
];

const categories = ['Todos', 'Residencial', 'Hotelero', 'Comercial'];

// Stats
const stats = [
  { number: '150+', label: 'Proyectos' },
  { number: '15+', label: 'Años' },
  { number: '50+', label: 'Hoteles' },
  { number: '100%', label: 'Satisfacción' },
];
---

<PageLayout
  title="Portafolio - VCG Caribe"
  description="Explora nuestros proyectos de cancelería en hoteles, residencias y edificios comerciales en Cancún, Riviera Maya y Yucatán."
>
  <!-- Hero Section with Background Image -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img
        src="/images/projects/paravian-fachada.jpg"
        alt="VCG Caribe Proyectos"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-deep/90 via-deep/70 to-deep"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 text-center relative z-10 py-20">
      <span class="inline-block px-4 py-2 bg-accent/20 text-accent font-semibold text-sm uppercase tracking-wider rounded-full mb-6 backdrop-blur-sm">
        Portafolio de Proyectos
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        Transformamos<br/>
        <span class="gradient-text">Espacios</span> en Arte
      </h1>
      <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto mb-12">
        Más de 15 años creando soluciones arquitectónicas en vidrio y aluminio
        para los proyectos más exigentes de la Península de Yucatán.
      </p>

      <!-- Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
        {stats.map((stat) => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/10">
            <div class="text-3xl md:text-4xl font-bold text-accent mb-1">{stat.number}</div>
            <div class="text-white/70 text-sm uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Filters - Sticky -->
  <section class="py-6 bg-white/95 backdrop-blur-lg sticky top-20 z-30 border-b border-gray-100 shadow-sm">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-3" id="filters">
        {categories.map((category, index) => (
          <button
            class={`px-6 py-2.5 rounded-full font-medium transition-all duration-300 filter-btn ${index === 0 ? 'bg-deep text-white shadow-lg' : 'bg-light text-muted hover:bg-deep/10 hover:text-deep'}`}
            data-category={category.toLowerCase()}
          >
            {category}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Mosaic Gallery -->
  <section class="py-16 bg-gradient-to-b from-light to-white">
    <div class="container mx-auto px-4">
      <!-- Mosaic Grid -->
      <div class="mosaic-grid" id="projects-grid">
        {projects.map((project, index) => {
          // Alternate border radius styles for visual variety
          const radiusClasses = [
            'rounded-[2rem_0.5rem_2rem_0.5rem]', // organic
            'rounded-[0.5rem_2rem_0.5rem_2rem]', // organic alt
            'rounded-[2rem_2rem_0.5rem_0.5rem]', // top rounded
            'rounded-[0.5rem_0.5rem_2rem_2rem]', // bottom rounded
            'rounded-3xl', // full rounded
            'rounded-[3rem_1rem]', // pill-ish
          ];
          const radiusClass = radiusClasses[index % radiusClasses.length];

          return (
          <div
            class={`mosaic-item mosaic-${project.size} project-item reveal group`}
            data-category={project.category.toLowerCase()}
            style={`animation-delay: ${index * 100}ms`}
          >
            <!-- Gradient border wrapper -->
            <div class={`relative w-full h-full p-[3px] ${radiusClass} bg-gradient-to-br from-accent via-navy to-accent shadow-xl group-hover:shadow-2xl group-hover:shadow-accent/20 transition-all duration-500`}>
              <div class={`relative w-full h-full overflow-hidden ${radiusClass} bg-deep`}>
                <!-- Image -->
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />

                <!-- Shine effect on hover -->
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 pointer-events-none"></div>

                <!-- Gradient Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-deep via-deep/40 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-500"></div>

                <!-- Corner accent -->
                <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-accent/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                <!-- Tags -->
                <div class="absolute top-4 left-4 flex gap-2 z-10">
                  <span class="px-3 py-1.5 bg-accent text-deep text-xs font-bold rounded-full shadow-lg">
                    {project.year}
                  </span>
                  <span class="px-3 py-1.5 bg-white/95 text-deep text-xs font-medium rounded-full shadow-lg backdrop-blur-sm">
                    {project.category}
                  </span>
                </div>

              <!-- Content Overlay -->
              <div class={`absolute inset-x-0 bottom-0 p-4 md:p-6 transform transition-transform duration-500 ${project.size === 'featured' || project.size === 'tall' ? 'translate-y-0' : 'translate-y-4 group-hover:translate-y-0'}`}>
                <!-- Location -->
                <div class={`flex items-center gap-2 text-accent text-sm mb-2 transition-opacity duration-500 ${project.size === 'featured' || project.size === 'tall' ? 'opacity-100' : 'opacity-0 group-hover:opacity-100 delay-100'}`}>
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  {project.location}
                </div>

                <!-- Title -->
                <h3 class={`font-bold text-white mb-2 leading-tight ${project.size === 'featured' ? 'text-2xl md:text-3xl' : 'text-lg md:text-xl'}`}>
                  {project.title}
                </h3>

                <!-- Specs Badges -->
                {project.specs && (
                  <div class={`flex flex-wrap gap-1.5 mb-3 transition-opacity duration-500 ${project.size === 'featured' || project.size === 'tall' ? 'opacity-100' : 'opacity-0 group-hover:opacity-100 delay-100'}`}>
                    {project.specs.map((spec: string) => (
                      <span class="px-2 py-0.5 bg-accent/20 text-accent text-xs font-medium rounded-md border border-accent/30">
                        {spec}
                      </span>
                    ))}
                  </div>
                )}

                <!-- Description -->
                <p class={`text-white/90 text-sm leading-relaxed transition-opacity duration-500 ${project.size === 'featured' ? 'line-clamp-4' : project.size === 'tall' ? 'line-clamp-3' : 'line-clamp-2 opacity-0 group-hover:opacity-100 delay-150'}`}>
                  {project.description}
                </p>

                <!-- View Button -->
                <div class={`mt-3 transition-opacity duration-500 ${project.size === 'featured' || project.size === 'tall' ? 'opacity-100' : 'opacity-0 group-hover:opacity-100 delay-200'}`}>
                  <span class="inline-flex items-center gap-2 px-4 py-2 bg-accent text-deep font-semibold text-sm rounded-lg group/btn hover:bg-accent/90 transition-colors">
                    Ver Detalles
                    <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </div>
          </div>
        )})}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="hidden text-center py-20">
        <div class="w-24 h-24 bg-light rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-12 h-12 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-deep mb-2">No hay proyectos en esta categoría</h3>
        <p class="text-muted">Intenta seleccionar otra categoría para ver más proyectos.</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-deep-gradient-mesh relative overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%2338bdf8&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block px-4 py-2 bg-accent/20 text-accent font-semibold text-sm uppercase tracking-wider rounded-full mb-6">
          ¿Listo para empezar?
        </span>
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          Tu proyecto puede ser<br/>
          <span class="gradient-text">el siguiente</span>
        </h2>
        <p class="text-white/70 text-lg md:text-xl max-w-2xl mx-auto mb-10">
          Contáctanos para discutir tu proyecto. Nuestro equipo de expertos
          está listo para convertir tu visión en realidad.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/contacto" variant="primary" size="lg">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            Cotizar Proyecto
          </Button>
          <Button href="https://wa.me/529982344274" variant="outline" size="lg">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </Button>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Mosaic Grid Layout */
  .mosaic-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 250px;
    grid-auto-flow: dense; /* Auto-fill gaps */
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .mosaic-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 280px;
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .mosaic-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 300px;
      gap: 1.5rem;
    }
  }

  /* Mosaic Item Sizes */
  .mosaic-featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .mosaic-wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  .mosaic-tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .mosaic-normal {
    grid-column: span 1;
    grid-row: span 1;
  }

  /* Mobile adjustments */
  @media (max-width: 767px) {
    .mosaic-featured {
      grid-column: span 2;
      grid-row: span 2;
    }

    .mosaic-wide {
      grid-column: span 2;
      grid-row: span 1;
    }

    .mosaic-tall {
      grid-column: span 1;
      grid-row: span 2;
    }

    .mosaic-normal {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  /* Line clamp for descriptions */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hide filtered items with animation */
  .project-item.filtered-out {
    display: none !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const projectItems = document.querySelectorAll('.project-item');
    const emptyState = document.getElementById('empty-state');
    const grid = document.getElementById('projects-grid');

    // Filter functionality
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');

        // Update active button
        filterBtns.forEach(b => {
          b.classList.remove('bg-deep', 'text-white', 'shadow-lg');
          b.classList.add('bg-light', 'text-muted');
        });
        btn.classList.remove('bg-light', 'text-muted');
        btn.classList.add('bg-deep', 'text-white', 'shadow-lg');

        // Filter projects with animation
        let visibleCount = 0;
        projectItems.forEach((item, index) => {
          const itemCategory = item.getAttribute('data-category');

          if (category === 'todos' || itemCategory === category) {
            item.classList.remove('filtered-out');
            item.style.animationDelay = `${visibleCount * 50}ms`;
            visibleCount++;
          } else {
            item.classList.add('filtered-out');
          }
        });

        // Show/hide empty state
        if (visibleCount === 0) {
          emptyState?.classList.remove('hidden');
          grid?.classList.add('hidden');
        } else {
          emptyState?.classList.add('hidden');
          grid?.classList.remove('hidden');
        }
      });
    });

    // Scroll reveal with Intersection Observer
    const revealElements = document.querySelectorAll('.reveal');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    revealElements.forEach(el => observer.observe(el));
  });
</script>
