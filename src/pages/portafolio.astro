    title: 'Lote 165 Arq. Santiago Silanes',
    category: 'Residencial',
    location: 'Puerto Cancún, Q. Roo',
    image: '/images/projects/lote-165.jpg',
    year: '2025',
    description: 'Ventanas de piso a techo con sistema euro de alta hermeticidad, puertas corredizas de gran formato (3.5m x 2.8m) con vidrio laminado 6+6mm, barandales minimalistas con vidrio templado 12mm y pasamanos de acero inoxidable satinado, y tragaluces fijos con control solar.',
    specs: ['Piso a techo', 'Laminado 6+6', 'Gran formato', 'Sistema euro'],
    size: 'normal',
  },
  {
    title: 'Cielo Maya Puerto Aventuras',
    category: 'Residencial',
    location: 'Puerto Aventuras, Q. Roo',
    image: '/images/projects/cielo-maya.jpg',
    year: '2025',
    description: 'Barandales interiores y exteriores con vidrio templado 10mm, cancelería de baño en aluminio acabado dorado, ventanas corredizas serie 3000 con mosquitero, y puertas abatibles con bisagras de cierre suave.',
    specs: ['Acabado dorado', 'Serie 3000', 'Templado 10mm', 'Cierre suave'],
    size: 'normal',
  },
  {
    title: 'Villa Magna Nápoles',
    category: 'Residencial',
    location: 'Ciudad de México',
    image: '/images/projects/villa-magna-bano.jpg',
    year: '2020',
    description: 'Baño de lujo con cancel de vidrio templado 10mm, ventanas fijas con vista a jardín tropical, acabados en mármol travertino y perfiles de aluminio anodizado bronce, herrajes de acero inoxidable pulido espejo.',
    specs: ['Mármol travertino', 'Templado 10mm', 'Anodizado bronce', 'Inox pulido'],
    size: 'normal',
  },
  {
    title: 'Paravian Exterior',
    category: 'Hotelero',
    location: 'Puerto Aventuras, Q. Roo',
    image: '/images/projects/paravian-exterior.jpg',
    year: '2025',
    description: 'Fachada de edificio hotelero con sistema de balcones de vidrio templado, louvers decorativos de aluminio color madera, ventanas de gran formato con perfiles minimalistas y acabados resistentes al ambiente costero.',
    specs: ['Balcones vidrio', 'Louvers aluminio', 'Gran formato', 'Costero'],
    size: 'wide',
  },
  {
    title: 'Paravian Interiores',
    category: 'Hotelero',
    location: 'Puerto Aventuras, Q. Roo',
    image: '/images/projects/paravian-interior.jpg',
    year: '2025',
    description: 'Interiores de lujo con barandales de vidrio templado 12mm, louvers de madera natural con sistema de iluminación integrada, escaleras con pasamanos de acero inoxidable y ventanas con marco oculto.',
    specs: ['Louvers madera', 'Vidrio 12mm', 'Marco oculto', 'Iluminación LED'],
    size: 'normal',
  },
  {
    title: 'Villa Magna Recámara',
    category: 'Residencial',
    location: 'Ciudad de México',
    image: '/images/projects/villa-magna-ventana.jpg',
    year: '2020',
    description: 'Recámara con ventanas horizontales de doble hoja y sistema proyectable, piso de madera maciza, perfiles de aluminio negro mate y vista panorámica a jardín tropical con palmeras.',
    specs: ['Doble hoja', 'Proyectable', 'Aluminio negro', 'Vista jardín'],
    size: 'normal',
  },
  {
    title: 'Royal 1',
    category: 'Hotelero',
    location: 'Riviera Maya, Q. Roo',
    image: '/images/projects/royal-1.jpg',
    year: '2023',
    description: 'Fachada con perfiles de muro cortina y sistema de aluminio compuesto, puertas automáticas de cristal con sensor de movimiento, barandales de balcón con vidrio laminado, mamparas de baño y puertas abatibles con herrajes tipo Stanley.',
    specs: ['Puertas automáticas', 'Herrajes Stanley', 'Laminado', 'Aluminio compuesto'],
    size: 'tall',
  },
  {
    title: 'Burger King Gran Plaza',
    category: 'Comercial',
    location: 'Cancún, Q. Roo',
    image: '/images/projects/burger-king.jpg',
    year: '2022',
