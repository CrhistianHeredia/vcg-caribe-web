---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';

const projects = [
  // Featured - Large
  {
    title: 'Paravian Torre A y B',
    category: 'Hotelero',
    location: 'Puerto Aventuras, Q. Roo',
    image: '/images/projects/paravian-fachada.jpg',
    year: '2025',
    description: 'Desarrollo hotelero de lujo con fachada de aluminio anodizado y louvers de madera, barandales de vidrio templado 12mm con acabado satinado, ventanas de piso a techo con sistema euro de alta hermeticidad y cancelería resistente al ambiente costero.',
    specs: ['Louvers madera', 'Vidrio 12mm', 'Sistema euro', 'Anti-corrosivo'],
    size: 'featured',
  },
  {
    title: 'Cielo Maya Ventana Circular',
    category: 'Residencial',
    location: 'Puerto Aventuras, Q. Roo',
    image: '/images/projects/cielo-maya-ventana.jpg',
    year: '2025',
    description: 'Ventana circular arquitectónica con marco de aluminio anodizado negro, vidrio templado de 10mm con tratamiento UV, diseño personalizado que enmarca el interior de lujo con acabados de madera natural.',
    specs: ['Ventana circular', 'Aluminio negro', 'Templado 10mm', 'Diseño único'],
    size: 'wide',
  },
  {
    title: 'Las Olas 71 Bahía Príncipe',
    category: 'Hotelero',
    location: 'Bahía Príncipe, Riviera Maya',
    image: '/images/projects/las-olas-71.jpg',
    year: '2025',
    description: 'Cancelería hotelera de alta especificación con vidrio templado de 10mm resistente a impacto, sistema de ventanas corredizas con cierre hermético para aislamiento acústico, barandales de balcón con vidrio laminado 6+6mm y herrajes de acero inoxidable 316L grado marino.',
