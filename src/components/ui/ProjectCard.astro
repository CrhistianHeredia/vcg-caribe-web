---
interface Props {
  title: string;
  category: string;
  image: string;
  href?: string;
  year?: string;
  class?: string;
}

const {
  title,
  category,
  image,
  href = '#',
  year,
  class: className = '',
} = Astro.props;
---

<a href={href} class={`project-card block aspect-[4/3] ${className}`}>
  <img
    src={image}
    alt={title}
    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    loading="lazy"
  />
  <div class="project-card-overlay"></div>
  <div class="project-card-content">
    {year && (
      <span class="inline-block px-2 py-1 bg-accent/20 text-accent text-xs rounded mb-2">
        {year}
      </span>
    )}
    <span class="block text-accent text-sm font-medium mb-1">{category}</span>
    <h3 class="text-xl font-bold">{title}</h3>
  </div>
</a>

<style>
  .project-card {
    @apply relative overflow-hidden rounded-xl cursor-pointer;
  }

  .project-card::before {
    content: '';
    @apply absolute inset-0 bg-gradient-to-t from-deep/90 via-deep/30 to-transparent opacity-60 transition-opacity duration-300 z-10;
  }

  .project-card:hover::before {
    @apply opacity-90;
  }

  .project-card-overlay {
    @apply absolute inset-0 bg-accent/10 opacity-0 transition-opacity duration-300 z-20;
  }

  .project-card:hover .project-card-overlay {
    @apply opacity-100;
  }

  .project-card-content {
    @apply absolute bottom-0 left-0 right-0 p-6 text-white z-30 transform translate-y-2 opacity-90 transition-all duration-300;
  }

  .project-card:hover .project-card-content {
    @apply translate-y-0 opacity-100;
  }
</style>
