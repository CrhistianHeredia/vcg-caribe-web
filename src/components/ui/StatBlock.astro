---
interface Props {
  number: string;
  label: string;
  suffix?: string;
  dark?: boolean;
  class?: string;
}

const {
  number,
  label,
  suffix = '',
  dark = false,
  class: className = '',
} = Astro.props;
---

<div class={`text-center p-6 ${className}`}>
  <div class={`text-4xl md:text-5xl lg:text-6xl font-bold mb-2 ${dark ? 'text-accent' : 'text-accent'}`}>
    <span class="stat-counter" data-target={number}>{number}</span>{suffix}
  </div>
  <p class={`text-sm uppercase tracking-wider ${dark ? 'text-white/70' : 'text-muted'}`}>
    {label}
  </p>
</div>
